{
  "name": "marketpiepie",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm --prefix backend run dev\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm run build --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
