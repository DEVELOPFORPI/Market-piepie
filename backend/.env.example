# Recommended for local development. Use production on the live server.
NODE_ENV=development

PORT=3001

# MySQL connection. Either DATABASE_URL or the DB_* fields below can be used.
DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/marketpiepie

# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=USER
# DB_PASSWORD=PASSWORD
# DB_NAME=marketpiepie

# Comma-separated origins for the frontend.
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173,http://localhost:3000

# Pi Network API key used by /api/payments/*.
# PI_API_KEY=

# Admin API password used through the x-admin-password header.
# ADMIN_PASSWORD=

# Set to true only if your MySQL provider requires TLS.
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
