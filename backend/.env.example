# 로컬: development 권장 (/api/auth/dev-login 활성화). 운영 서버: production
# NODE_ENV=development

PORT=3001
# 선택: PostgreSQL 연결 문자열 (없으면 헬스체크만, db는 skipped)
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/marketpiepie
#
# Supabase: 대시보드에 "Not IPv4 compatible" 이면 Direct(db...:5432) 대신
# Connection settings에서 "Session pooler"(또는 Transaction) 모드 URI를 복사해 DATABASE_URL에 사용.
# 콤마로 여러 origin (Vercel + 로컬 Vite 등)
# CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173,http://localhost:3000

# Pi Network API (결제 승인 등 /api/payments/* 에서 사용). 소스에 넣지 말 것.
# PI_API_KEY=

# 관리자 API (x-admin-password). 서버에만 저장하고 프론트 env에는 넣지 말 것.
# ADMIN_PASSWORD=

# 노출된 적이 있으면 Supabase·Pi 키·DB 비밀번호는 반드시 교체할 것.
