# Recommended for local development. Use production on the live server.
NODE_ENV=development

PORT=3001

# MySQL connection. Either DATABASE_URL or the DB_* fields below can be used.
DATABASE_URL=mysql://USER:PASSWORD@localhost:3306/marketpiepie

# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=USER
# DB_PASSWORD=PASSWORD
# DB_NAME=marketpiepie

# Comma-separated origins for the frontend.
# Defaults already include localhost, blindlounge.xyz, pie.blindlounge.xyz,
# https://market-piepie-frontend.vercel.app, and https://piepie-market.vercel.app.
# Add extra deployment/preview domains here.
# CORS_ORIGIN=https://market-piepie-frontend.vercel.app,http://localhost:5173,http://localhost:3000

# Pi Network API key used by /api/payments/*.
# PI_API_KEY=

# Admin API password used through the x-admin-password header.
# ADMIN_PASSWORD=

# Cloudflare R2 image uploads. Keep these values on the backend only.
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET=marketpiepie-images
# Optional public bucket/custom domain base URL, no trailing slash.
# If blank, uploaded images are served through /api/uploads/object/:key.
# R2_PUBLIC_URL=https://images.example.com
# Optional:
# R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
# R2_REGION=auto
# R2_UPLOAD_PREFIX=uploads
# R2_MAX_UPLOAD_MB=8

# Set to true only if your MySQL provider requires TLS.
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
