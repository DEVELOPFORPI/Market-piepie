# Vite — 접두사 VITE_ 만 브라우저에 노출됩니다.
# 복사 후 .env 또는 .env.local 로 저장하고 값 채우기 (이 파일에는 비밀번호를 커밋하지 마세요).
#
# Next.js 의 NEXT_PUBLIC_SUPABASE_* 와 같지 않습니다. 이 저장소는 Vite 이므로 아래 이름을 씁니다.

# API 서버 (예: http://localhost:3001 또는 배포 URL)
# 로컬 개발은 기본적으로 Vite proxy -> http://localhost:4000 을 사용합니다.
# 프로덕션 기본 API는 https://pie.blindlounge.xyz 입니다.
# 필요하면 아래 값으로 명시 오버라이드할 수 있습니다.
# VITE_API_URL=https://pie.blindlounge.xyz
# VITE_API_BASE_URL=https://pie.blindlounge.xyz

# Supabase (Realtime 등 — 대시보드 → API Keys)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# Publishable 키(sb_publishable_...) 또는 Legacy anon 키 — 둘 다 여기에 넣으면 됩니다.
# VITE_SUPABASE_ANON_KEY=sb_publishable_...

# 관리자 비밀번호는 프론트 환경변수에 넣지 않습니다.
# 관리자 화면에서 입력한 값만 세션에 보관하고, 서버 ADMIN_PASSWORD 와 비교합니다.

# Pi SDK 모드 (test 브랜치 = true, main 브랜치 = false)
# 절대 index.html 에 박지 말 것. 브랜치 머지 사고 1순위.
# VITE_PI_SANDBOX=true

# 로컬 dev 서버에서 /api·/socket.io 가 향할 백엔드 주소.
# Vite dev 전용. 빌드 결과물에는 들어가지 않습니다.
# 기본값: http://localhost:4000 (같은 머신에 백엔드를 띄운 경우)
# Lightsail로 붙으려면: https://api-test.example.com 같이 도메인 입력.
# DEV_API_TARGET=http://localhost:4000
